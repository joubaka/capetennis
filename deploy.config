# Laravel Deployment Configuration
# Cape Tennis - Similar to jouberttennis.co.za setup
# Customize these values for your environment

# ===============================
# DEPLOYMENT SETTINGS
# ===============================
DEPLOY_ENV=production
# Using absolute path to prevent expansion errors
APP_PATH="/home/batawrry/domains/capetennis.co.za/laraval_app"

# PUBLIC_HTML is where your web server serves files from
PUBLIC_HTML="/home/batawrry/domains/capetennis.co.za/public_html"

# Git branch to deploy from
GIT_BRANCH=player-update

# ===============================
# DATABASE
# ===============================
DB_HOST=localhost
DB_PORT=3306
DB_DATABASE=capetennis
DB_USERNAME=root
DB_PASSWORD=

# ===============================
# CACHING & OPTIMIZATION
# ===============================
CACHE_DRIVER=redis
QUEUE_DRIVER=sync
SESSION_DRIVER=file

# ===============================
# ASSET SYNC (Important for shared hosting!)
# ===============================
# Folders to sync from public/ → PUBLIC_HTML/
SYNC_FOLDERS="css js images vendors assets"
SYNC_ROOT_FILES="favicon.ico manifest.json robots.txt firebase-messaging-sw.js"

# ===============================
# DATABASE & MIGRATIONS
# ===============================
RUN_MIGRATIONS=true
SEED_DATABASE=false

# ===============================
# BACKUP & RETENTION
# ===============================
BACKUP_ENV_FILE=true
BACKUP_RETENTION_DAYS=30
BACKUP_COMPRESS=true

# ===============================
# NOTIFICATIONS (Optional)
# ===============================
DEPLOY_NOTIFY_EMAIL=support@capetennis.co.za
DEPLOY_SLACK_WEBHOOK=
DEPLOY_DISCORD_WEBHOOK=

# ===============================
# SERVICE RESTART (Production only)
# ===============================
RESTART_APACHE=false
RESTART_NGINX=false
RESTART_PHP_FPM=false

# ===============================
# ASSET COMPILATION
# ===============================
COMPILE_ASSETS=true
NPM_BUILD_COMMAND="npm run build"
VITE_BUILD=true
